{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/search",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/news",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/realestate",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/ai-news",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/stock-recommend",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/admin/**",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/webhook/**",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/stock-ai",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/stock-news",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      },
      {
        "source": "/scheduler/ainews",
        "run": {
          "serviceId": "smart-hub-api",
          "region": "asia-northeast3"
        }
      }
    ]
  }
}
