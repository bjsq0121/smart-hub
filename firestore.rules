rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 화이트리스트: 본인 문서만 읽기, admin만 전체 읽기/쓰기
    match /allowed_emails/{email} {
      allow read: if request.auth != null
        && (request.auth.token.email == email
            || (exists(/databases/$(database)/documents/allowed_emails/$(request.auth.token.email))
                && get(/databases/$(database)/documents/allowed_emails/$(request.auth.token.email)).data.role == 'admin'));
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/allowed_emails/$(request.auth.token.email))
        && get(/databases/$(database)/documents/allowed_emails/$(request.auth.token.email)).data.role == 'admin';
    }
    // 알림: 인증 유저만 읽기, read 필드만 업데이트 허용
    match /notifications/{notiId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }
    // 운영 대시보드 컬렉션: 인증 유저는 읽기만, 쓰기는 백엔드(Admin SDK)만
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /balances/{balanceId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /workflow_runs/{runId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // crypto 검증 허브 컬렉션
    match /signals/{signalId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /paper_trades/{tradeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /trade_results/{resultId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /system_status/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // 주식 paper 포지션 (파생 캐시) — 서버 SDK만 접근
    match /paper_positions/{symbol} {
      allow read, write: if false;
    }
    // 자동매매 중복 방지 + 설정 — 서버 SDK만 접근
    match /autotrade_processed/{signalId} {
      allow read, write: if false;
    }
    match /settings/{docId} {
      allow read, write: if false;
    }
    // 그 외 모든 컬렉션 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
